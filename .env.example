# AI Workforce Intelligence Agent Environment Configuration

# Application Mode: development, staging, production
APP_ENV=development

# Streamlit config
STREAMLIT_PORT=8501
STREAMLIT_ADDRESS=0.0.0.0

# API Keys (Replace with your actual keys in local .env file)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Search Tool configuration (Optional)
TAVILY_API_KEY=your_tavily_api_key_here

# Logging
LOG_LEVEL=INFO
